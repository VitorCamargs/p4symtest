      "(let ((a!1 (ite (= ipv4.dstAddr #x0a00010a)\n                #b000000001\n                (ite (= ((_ extract 31 8) ipv4.dstAddr) #x0a0002)\n                     #b000000010\n                     standard_metadata.egress_spec))))\n  (distinct #b111111111 a!1))"

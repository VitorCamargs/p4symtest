[
  {
    "description": "parser ipv4 -> MyIngress.ipv4_lpm",
    "z3_constraints_smt2": [
      "(= ipv4.$valid$ #b1)",
      "(distinct #b111111111 standard_metadata.egress_spec)"
    ],
    "present_headers": ["ethernet", "ipv4"],
    "history": ["Parser", "MyIngress.ipv4_lpm"],
    "field_updates": {
      "standard_metadata.egress_spec": "#b000000001",
      "ethernet.dstAddr": "#x000000000100",
      "ipv4.ttl": "(bvadd #xff ipv4.ttl)"
    }
  },
  {
    "description": "parser non-ipv4",
    "z3_constraints_smt2": [
      "(= ipv4.$valid$ #b0)"
    ],
    "present_headers": ["ethernet"],
    "history": ["Parser"]
  }
]
